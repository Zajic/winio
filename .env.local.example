# Supabase (z Bloku 1.2)
# Zkopíruj do .env.local a doplň hodnoty z Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tvuj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tvuj-anon-key

# Základní URL webu (pro Schema.org a sdílení). Na Vercelu: https://tvoje-domena.vercel.app
NEXT_PUBLIC_SITE_URL=

# Service role (pouze pro server – cron, zápis zapasy/kurzy). Dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=

# Cron: volání /api/cron/odds (Vercel Cron nebo externě). Nastav v Vercel → Settings → Environment Variables
CRON_SECRET=

# The Odds API (the-odds-api.com). Pro cron načítání zápasů a kurzů.
ODDS_API_KEY=
# Sporty (klíče API), čárkou oddělené. Např. soccer_eurocup,icehockey_nhl
ODDS_API_SPORTS=

# Blok 10 (volitelně): OpenAI pro generování SEO preview zápasů. Cron /api/cron/seo-preview (denně).
OPENAI_API_KEY=

# Blok 11.2: RSS zdroje článků (URL čárkou oddělené). Cron /api/cron/rss.
RSS_FEEDS=

# Blok 14: Apify – aktualizace poboček. Cron /api/cron/pobocky (měsíčně).
# APIFY_ACTOR_ID = owner~actor-name (např. username~store-locations)
# APIFY_SAZKOVKA_ID = UUID sázkovky z tabulky sazkovky
APIFY_API_TOKEN=
APIFY_ACTOR_ID=
APIFY_SAZKOVKA_ID=

# Blok 17: Sledování konverzí (načítá se jen při cookie souhlasu).
# Stačí jeden: GA4 nebo Plausible
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
